<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://flowable.org/test">

    <process id="leaveApproval" name="请假审批流程" isExecutable="true">
        
        <startEvent id="startEvent" name="开始"/>
        
        <userTask id="submitLeave" name="提交请假申请" flowable:assignee="${applicant}">
            <extensionElements>
                <flowable:formProperty id="days" name="请假天数" type="long" required="true"/>
                <flowable:formProperty id="reason" name="请假原因" type="string" required="true"/>
                <flowable:formProperty id="startDate" name="开始日期" type="date" required="true"/>
            </extensionElements>
        </userTask>
        
        <userTask id="deptManagerApproval" name="部门经理审批" flowable:assignee="${deptManager}">
            <extensionElements>
                <flowable:formProperty id="deptApproved" name="部门经理意见" type="enum" required="true">
                    <flowable:value id="true" name="同意"/>
                    <flowable:value id="false" name="拒绝"/>
                </flowable:formProperty>
                <flowable:formProperty id="deptComment" name="审批意见" type="string"/>
            </extensionElements>
        </userTask>
        
        <exclusiveGateway id="checkDays" name="检查请假天数"/>
        
        <userTask id="hrApproval" name="HR审批" flowable:assignee="${hrManager}">
            <extensionElements>
                <flowable:formProperty id="hrApproved" name="HR意见" type="enum" required="true">
                    <flowable:value id="true" name="同意"/>
                    <flowable:value id="false" name="拒绝"/>
                </flowable:formProperty>
                <flowable:formProperty id="hrComment" name="HR意见" type="string"/>
            </extensionElements>
        </userTask>
        
        <userTask id="gmApproval" name="总经理审批" flowable:assignee="${generalManager}">
            <extensionElements>
                <flowable:formProperty id="gmApproved" name="总经理意见" type="enum" required="true">
                    <flowable:value id="true" name="同意"/>
                    <flowable:value id="false" name="拒绝"/>
                </flowable:formProperty>
                <flowable:formProperty id="gmComment" name="总经理意见" type="string"/>
            </extensionElements>
        </userTask>
        
        <parallelGateway id="parallelGatewayStart" name="并行审批开始"/>
        <parallelGateway id="parallelGatewayEnd" name="并行审批结束"/>
        <exclusiveGateway id="mergeGateway" name="汇总"/>
        
        <userTask id="notifyApplicant" name="通知申请人" flowable:assignee="${applicant}">
            <extensionElements>
                <flowable:formProperty id="finalResult" name="审批结果" type="string"/>
            </extensionElements>
        </userTask>
        
        <endEvent id="endEvent" name="结束"/>
        
        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="submitLeave"/>
        <sequenceFlow id="flow2" sourceRef="submitLeave" targetRef="deptManagerApproval"/>
        <sequenceFlow id="flow3" sourceRef="deptManagerApproval" targetRef="checkDays"/>
        
        <sequenceFlow id="flow4" name="≤3天" sourceRef="checkDays" targetRef="mergeGateway">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${days <= 3}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <sequenceFlow id="flow5" name=">3天" sourceRef="checkDays" targetRef="parallelGatewayStart">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${days > 3}]]>
            </conditionExpression>
        </sequenceFlow>
        
        <sequenceFlow id="flow6" sourceRef="parallelGatewayStart" targetRef="hrApproval"/>
        <sequenceFlow id="flow7" sourceRef="parallelGatewayStart" targetRef="gmApproval"/>
        <sequenceFlow id="flow8" sourceRef="hrApproval" targetRef="parallelGatewayEnd"/>
        <sequenceFlow id="flow9" sourceRef="gmApproval" targetRef="parallelGatewayEnd"/>
        <sequenceFlow id="flow10" sourceRef="parallelGatewayEnd" targetRef="mergeGateway"/>
        <sequenceFlow id="flow11" sourceRef="mergeGateway" targetRef="notifyApplicant"/>
        <sequenceFlow id="flow12" sourceRef="notifyApplicant" targetRef="endEvent"/>
        
    </process>

    <bpmndi:BPMNDiagram id="BPMNDiagram_leaveApproval">
