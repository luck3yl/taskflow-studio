                <omgdi:waypoint x="830.0" y="238.0"/>
                <omgdi:waypoint x="830.0" y="258.0"/>
            </bpmndi:BPMNEdge>
            
            <bpmndi:BPMNEdge bpmnElement="flow9" id="BPMNEdge_flow9">
                <omgdi:waypoint x="760.0" y="358.0"/>
                <omgdi:waypoint x="830.0" y="358.0"/>
                <omgdi:waypoint x="830.0" y="298.0"/>
