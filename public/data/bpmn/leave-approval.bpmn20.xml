                <omgdi:waypoint x="920.0" y="100.0"/>
                <omgdi:waypoint x="920.0" y="158.0"/>
            </bpmndi:BPMNEdge>
            
            <bpmndi:BPMNEdge bpmnElement="flow5" id="BPMNEdge_flow5">
